{
  "title": "k6 Performance Test",
  "uid": "k6-perf",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 2,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "Virtual Users",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "VUs"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "k6_error_rate",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "id": 5,
      "title": "HTTP Request Failed",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(k6_http_req_failed_total[1m]))",
          "legendFormat": "failed/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Smoke Duration (p95)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_smoke_duration_milliseconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(k6_smoke_duration_milliseconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 7,
      "title": "Iterations Total",
      "type": "stat",
      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "k6_iterations_total",
          "legendFormat": "iterations"
        }
      ]
    },
    {
      "id": 8,
      "title": "Success Count",
      "type": "stat",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "k6_success_count_total",
          "legendFormat": "success"
        }
      ]
    }
  ],
  "datasource": {
    "type": "prometheus",
    "uid": "${DS_PROMETHEUS-LMS}"
  },
  "__inputs": [
    {
      "name": "DS_PROMETHEUS-LMS",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ]
}
